# Vite Configuration
VITE_BACKEND_URL=localhost:8055
VITE_CACHE_BACKEND=OFF
# Static Directus tokens for the alias accounts. To keep them out of the built
# bundle as plain text, obfuscate before pasting: `npm run obfuscate-token -- <token>`
# and use the resulting `obf:...` value. NOTE: this is deterrence only, not real
# security -- the token can still be read from the network tab (see
# src/assets/js/obfuscation.js). A plain token also works (used verbatim).
#
# Token for the default alias (VITE_DEFAULT_USER_ALIAS):
VITE_AUTH_TOKEN=CHANGE_THIS_AFTER_DIRECTUS_STARTED
# Token for the special "Kleiner-AK" alias (VITE_SPECIAL_USER_ALIAS). It is
# backed by its own remote account, so it needs its own token. Leave empty (or
# as the placeholder) to reuse VITE_AUTH_TOKEN.
VITE_SPECIAL_AUTH_TOKEN=CHANGE_THIS_AFTER_DIRECTUS_STARTED
VITE_MAILTO_EMAIL=example@mail.adress

# Frontend Configuration used when behind nginx reverse proxy
FRONTEND_VIRTUAL_HOST=example-frontend-virtual-host.com
FRONTEND_LETSENCRYPT_HOST=example-frontend-virtual-host.com
LETSENCRYPT_EMAIL=example@example.com

# Database Configuration
POSTGRES_USER=GB_DASHBOARD_DB_USER
POSTGRES_PASSWORD=GB_DASHBOARD_DB_SUPER_SECRET_PASSWORD
POSTGRES_DB=GB_DASHBOARD_DB

# Backend Configuration
BACKEND_PUBLIC_PORT=8055
SECRET=DIRECTUS_SECRET

# Admin Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password

# URLs
BACKEND_URL=http://localhost:8055
FRONTEND_URL=http://localhost:8052

# CORS Configuration
CORS_ORIGIN=*

# Email Configuration
EMAIL_VERIFY_SETUP=false
EMAIL_FROM=example@example.com
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_email_smtp_user
EMAIL_SMTP_PASSWORD=your_email_smtp_password
EMAIL_SMTP_POOL=true
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_IGNORE_TLS=false
EMAIL_SMTP_NAME=Example SMTP Name

# User Group Configuration
VITE_DEFAULT_USER_ALIAS=AK-Gesangbuch
VITE_DEFAULT_USER_NAME=info@example.com
VITE_SPECIAL_USER_ALIAS=Kleiner-AK
VITE_SPECIAL_USER_NAME=special@example.com
VITE_KLEINER_KREIS_USERS=special@example.com,another@example.com

# Comma-separated Directus role names allowed to access notentext upload/export views.
# Leave empty to disable the role check (any logged-in user may access).
VITE_NOTENTEXT_ROLES=

# Comma-separated Directus role names that get Kleiner-Kreis features. Members of
# these roles unlock the Kleiner-Kreis view by role alone, so they no longer need
# to be listed in VITE_KLEINER_KREIS_USERS. Leave empty to rely solely on that list.
VITE_KLEINER_KREIS_ROLES=Super-Editor,Administrator

# Directus folder UUID that notentext uploads (SVG/MXL) are placed into.
# Leave empty to upload to the instance default folder (root).
VITE_NOTENTEXT_FOLDER_ID=

# Directus folder UUID that Finale source files (.musx/.mus) are placed into.
# Leave empty to fall back to the built-in default folder.
VITE_FINALE_FOLDER_ID=

# Directus folder UUID that MIDI files (.mid/.midi) are placed into.
# Leave empty to fall back to the built-in default folder.
VITE_MIDI_FOLDER_ID=

# Directus file UUID der statischen KI-Review-Datei (Autoren-Datencheck, Issue #32),
# geladen über /assets/<UUID>. Leer lassen, um die im Code hinterlegte Standard-UUID
# zu verwenden. So lässt sich eine neue Auswertung ohne Deploy einspielen.
VITE_AUTOR_REVIEW_FILE_ID=

# Passed into the nginx.conf.template
NGINX_SERVER_NAME=localhost:5173/
